# Run-crond daemon for KernelSU initrc injection.
#
# KernelSU hooks init's read() on init.rc and appends this file's content
# so init treats the service definition below as part of init.rc itself.
#
# Starts after sys.boot_completed=1.
# Runs as u:r:ksu:s0 (KernelSU's permissive domain — no SELinux denials).
# OOM-protected (oom_score_adj -1000 = immune to Low Memory Killer).
# Auto-restart on crash (init restarts on exit, no watchdog needed).

service dailyjobs-crond /data/adb/modules/dailyjobs/run-crond.sh
    class late_start
    user root
    group root
    disabled
    oom_score_adj -1000

on property:sys.boot_completed=1
    start dailyjobs-crond
